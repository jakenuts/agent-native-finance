# Finance local development example.
# Keep real values in local .env, Nisse project env vars, GitHub Actions
# secrets, and Railway variables. Never commit real secrets.

# Local data/auth defaults
DATABASE_URL=file:./data/app.db
FINANCE_OWNER_EMAIL=owner@finance.local
FINANCE_DISABLE_SCHEDULER=true
AUTH_DISABLED=true
# Set true in production after the owner account exists for single-tenant installs.
# FINANCE_BLOCK_SIGNUP=false

# Agent runtime. Configure at least one provider for in-app AI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Production auth and signing secrets. Generate each independently.
# BETTER_AUTH_URL=https://your-production-domain.example
# BETTER_AUTH_SECRET=
# OAUTH_STATE_SECRET=
# A2A_SECRET=
# SECRETS_ENCRYPTION_KEY=

# Database provider auth, when the provider requires a separate token.
# DATABASE_AUTH_TOKEN=

# Plaid
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# PLAID_WEBHOOK_URL=https://your-production-domain.example/api/plaid-webhook
# PLAID_REDIRECT_URI=https://your-production-domain.example/plaid/callback

# Optional Recurly projected-income automation.
# Manual projected entries and Recurly CSV import work without this key.
RECURLY_API_KEY=
RECURLY_SUBDOMAIN=app

# Deployment tooling for agents, not app runtime.
# RAILWAY_TOKEN=
